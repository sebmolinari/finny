# Server Configuration
PORT=5000
NODE_ENV=development

# Security
JWT_SECRET=<your-jwt-secret-here>
JWT_EXPIRATION=12h

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10000

# Database
DATABASE_PATH=./database.db
DB_KEY=<your-database-encryption-key-here> #min 8 characters

# Supabase Configuration
SUPABASE_ENABLED=false # Set to true if using Supabase as the database
SUPABASE_URL=<your-supabase-url-here> #only requred if Supabase is used
SUPABASE_API_KEY=<your-supabase-api-key-here> #only requred if Supabase is used

# Email Configuration (for portfolio summary emails)
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=<your-app-password>
EMAIL_FROM_NAME=Finny Portfolio Manager
EMAIL_FROM_ADDRESS=noreply@finny.com